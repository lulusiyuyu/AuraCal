# AuraCal Backend — Environment Variables Example

# AI Providers (system default keys, optional)
# Users can provide their own keys via the frontend Settings panel
DEFAULT_AI_PROVIDER=minimax
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./auracal.db

# App secret (change this to a random string in production)
SECRET_KEY=auracal-dev-secret-change-me
